#!/usr/bin/env php
<?php

declare(strict_types=1);

use Symfony\Component\Console\Application;

use Totoglu\Console\Commands\MakeModuleCommand;
use Totoglu\Console\Commands\UserCreateCommand;
use Totoglu\Console\Commands\UserListCommand;
use Totoglu\Console\Commands\UserUpdateCommand;
use Totoglu\Console\Commands\UserDeleteCommand;
use Totoglu\Console\Commands\ModuleListCommand;
use Totoglu\Console\Commands\ModuleInstallCommand;
use Totoglu\Console\Commands\ModuleUninstallCommand;
use Totoglu\Console\Commands\ModuleRefreshCommand;

use Totoglu\Console\Commands\ModuleUpgradeCommand;
use Totoglu\Console\Commands\TinkerCommand;
use Totoglu\Console\Commands\DbBackupCommand;
use Totoglu\Console\Commands\DbRestoreCommand;
use Totoglu\Console\Commands\BackupListCommand;
use Totoglu\Console\Commands\BackupPurgeCommand;
use Totoglu\Console\Commands\CacheWireClearCommand;
use Totoglu\Console\Commands\PageListCommand;
use Totoglu\Console\Commands\PageFindCommand;
use Totoglu\Console\Commands\PageCreateCommand;
use Totoglu\Console\Commands\PagePublishCommand;
use Totoglu\Console\Commands\PageUnpublishCommand;
use Totoglu\Console\Commands\PageTrashCommand;
use Totoglu\Console\Commands\PageMoveCommand;
use Totoglu\Console\Commands\PageRestoreCommand;
use Totoglu\Console\Commands\PageUpdateCommand;
use Totoglu\Console\Commands\LogListCommand;
use Totoglu\Console\Commands\LogReadCommand;
use Totoglu\Console\Commands\LogTailCommand;
use Totoglu\Console\Commands\LogClearCommand;
use Totoglu\Console\Commands\LogClearAllCommand;
use Totoglu\Console\Commands\FieldListCommand;
use Totoglu\Console\Commands\FieldDeleteCommand;
use Totoglu\Console\Commands\FieldInfoCommand;
use Totoglu\Console\Commands\FieldUpdateCommand;
use Totoglu\Console\Commands\FieldRenameCommand;
use Totoglu\Console\Commands\FieldAttachCommand;
use Totoglu\Console\Commands\FieldDetachCommand;
use Totoglu\Console\Commands\TemplateListCommand;
use Totoglu\Console\Commands\TemplateDeleteCommand;
use Totoglu\Console\Commands\TemplateInfoCommand;
use Totoglu\Console\Commands\TemplateFieldsReorderCommand;
use Totoglu\Console\Commands\TemplateUpdateCommand;
use Totoglu\Console\Commands\TemplateRenameCommand;
use Totoglu\Console\Commands\RoleListCommand;
use Totoglu\Console\Commands\RoleCreateCommand;
use Totoglu\Console\Commands\RoleGrantCommand;
use Totoglu\Console\Commands\RoleRevokeCommand;
use Totoglu\Console\Commands\PermissionListCommand;
use Totoglu\Console\Commands\PermissionCreateCommand;
use Totoglu\Console\Commands\PermissionDeleteCommand;
use Totoglu\Console\Commands\CacheClearCommand;
use Totoglu\Console\Commands\VersionCommand;
use Totoglu\Console\Commands\MakeMigrationCommand;
use Totoglu\Console\Commands\MakeSeederCommand;
use Totoglu\Console\Commands\DbSeedCommand;
use Totoglu\Console\Commands\MakeQueueCommand;
use Totoglu\Console\Commands\MakeTaskCommand;
use Totoglu\Console\Commands\ScheduleRunCommand;
use Totoglu\Console\Commands\DownCommand;
use Totoglu\Console\Commands\UpCommand;
use Totoglu\Console\Commands\MigrateCommand;
use Totoglu\Console\Commands\MigrateRollbackCommand;
use Totoglu\Console\Commands\MigrateResetCommand;
use Totoglu\Console\Commands\MigrateRefreshCommand;
use Totoglu\Console\Commands\MigrateFreshCommand;
use Totoglu\Console\Commands\MigrateStatusCommand;
use Totoglu\Console\Commands\MigrateInstallCommand;

use Totoglu\Console\Commands\QueueTableCommand;
use Totoglu\Console\Commands\QueueWorkCommand;
use Totoglu\Console\Commands\QueueFailedCommand;
use Totoglu\Console\Commands\QueueRetryCommand;
use Totoglu\Console\Commands\QueueClearCommand;

/**
 * Locate the Composer autoloader.
 */
$autoloader = null;

// Usually Composer sets this global variable when calling via vendor/bin
if (isset($GLOBALS['_composer_autoload_path']) && file_exists($GLOBALS['_composer_autoload_path'])) {
    $autoloader = $GLOBALS['_composer_autoload_path'];
} else {
    // Fallbacks
    $candidates = [
        __DIR__ . '/../vendor/autoload.php',          // Local dev inside the package
        __DIR__ . '/../../../vendor/autoload.php',    // If package is nested inside /src folder and root has vendor/
        __DIR__ . '/../../../autoload.php',           // Typical vendor/trk/package/bin/
        __DIR__ . '/../../vendor/autoload.php',       // Typical root dev
        __DIR__ . '/../../../../vendor/autoload.php', // If symlinked and 3 dirs deep
    ];

    foreach ($candidates as $candidate) {
        if (file_exists($candidate)) {
            $autoloader = $candidate;
            break;
        }
    }
}

if (!$autoloader || !file_exists($autoloader)) {
    echo "Error: Could not locate composer autoloader.\n";
    exit(1);
}

$autoloader = realpath($autoloader);

require $autoloader;

/**
 * Locate ProcessWire root and bootstrap core.
 */
$pwRoot = null;
$tempRoot = dirname($autoloader, 2);

// Go up until we find the 'wire' directory
while ($tempRoot !== '/' && !empty($tempRoot)) {
    if (file_exists($tempRoot . '/wire/core/ProcessWire.php')) {
        $pwRoot = realpath($tempRoot);
        break;
    }
    $parent = dirname($tempRoot);
    if ($parent === $tempRoot) break;
    $tempRoot = $parent;
}

if (!$pwRoot) {
    echo "Error: Could not locate ProcessWire core (wire/core/ProcessWire.php) in any parent directory of {$autoloader}.\n";
    exit(1);
}

if (!class_exists('\ProcessWire\ProcessWire', false)) {
    require_once($pwRoot . '/wire/core/ProcessWire.php');
}

// Manual Clean Bootstrap
$_SERVER['HTTP_HOST'] = 'localhost';
$wire = null;

try {
    $config = \ProcessWire\ProcessWire::buildConfig($pwRoot);
    // Only attempt full bootstrap if database is configured
    if ($config->dbName) {
        $wire = new \ProcessWire\ProcessWire($config);
    }
} catch (\Throwable $e) {
    // Database or config issue - continue to show basic CLI helps
}

$consoleVersion = '1.0.0';
if (class_exists('\Composer\InstalledVersions')) {
    try {
        $consoleVersion = \Composer\InstalledVersions::getPrettyVersion('trk/processwire-console') ?? '1.0.0';
    } catch (\Throwable $e) {}
}

$pwVersion = 'Unknown';
if (class_exists('\ProcessWire\ProcessWire', false)) {
    $pwVersion = \ProcessWire\ProcessWire::versionMajor . '.' . \ProcessWire\ProcessWire::versionMinor . '.' . \ProcessWire\ProcessWire::versionRevision;
    if (\ProcessWire\ProcessWire::versionSuffix) {
        $pwVersion .= '-' . \ProcessWire\ProcessWire::versionSuffix;
    }
}

$argv = $_SERVER['argv'] ?? [];
if (in_array('--version', $argv) || in_array('-V', $argv)) {
    // Check if there is a 'boost' context
    if (isset($argv[1]) && str_starts_with($argv[1], 'boost')) {
        $boostVersion = 'Unknown';
        if (class_exists('\Composer\InstalledVersions')) {
            try {
                $boostVersion = \Composer\InstalledVersions::getPrettyVersion('trk/processwire-boost') ?? 'Unknown';
            } catch (\Throwable $e) {}
        }
        echo "ProcessWire Boost $boostVersion\n";
        exit(0);
    }
}

$applicationVersion = $consoleVersion . ' (ProcessWire ' . $pwVersion . ')';
$application = new Application('ProcessWire Command Line Interface', $applicationVersion);
// Core Commands
$application->addCommands([

    new MakeModuleCommand(),
    new UserCreateCommand(),
    new UserListCommand(),
    new UserUpdateCommand(),
    new UserDeleteCommand(),
    new RoleListCommand(),
    new RoleCreateCommand(),
    new RoleGrantCommand(),
    new RoleRevokeCommand(),
    new PermissionListCommand(),
    new PermissionCreateCommand(),
    new PermissionDeleteCommand(),
    new PageListCommand(),
    new PageFindCommand(),
    new PageCreateCommand(),
    new PagePublishCommand(),
    new PageUnpublishCommand(),
    new PageTrashCommand(),
    new PageMoveCommand(),
    new PageRestoreCommand(),
    new PageUpdateCommand(),
    new FieldListCommand(),
    new FieldDeleteCommand(),
    new FieldInfoCommand(),
    new FieldUpdateCommand(),
    new FieldRenameCommand(),
    new FieldAttachCommand(),
    new FieldDetachCommand(),
    new TemplateListCommand(),
    new TemplateDeleteCommand(),
    new TemplateInfoCommand(),
    new TemplateFieldsReorderCommand(),
    new TemplateUpdateCommand(),
    new TemplateRenameCommand(),
    new ModuleListCommand(),
    new ModuleInstallCommand(),
    new ModuleUninstallCommand(),
    new ModuleRefreshCommand(),

    new ModuleUpgradeCommand(),
    new TinkerCommand(),
    new DbBackupCommand(),
    new DbRestoreCommand(),
    new BackupListCommand(),
    new BackupPurgeCommand(),
    new LogListCommand(),
    new LogReadCommand(),
    new LogTailCommand(),
    new LogClearCommand(),
    new LogClearAllCommand(),
    new CacheWireClearCommand(),
    new CacheClearCommand(),
    new VersionCommand(),
    new MakeSeederCommand(),
    new DbSeedCommand(),
    // Scheduling Commands
    new MakeTaskCommand(),
    new ScheduleRunCommand(),
    
    // Maintenance Commands
    new DownCommand(),
    new UpCommand(),

    // Migration Commands
    new MakeMigrationCommand(),
    new MakeQueueCommand(),
    new MigrateCommand(),
    new MigrateRollbackCommand(),
    new MigrateResetCommand(),
    new MigrateRefreshCommand(),
    new MigrateFreshCommand(),
    new MigrateStatusCommand(),
    new MigrateInstallCommand(),
    // Queue Commands
    new QueueTableCommand(),
    new QueueWorkCommand(),
    new QueueFailedCommand(),
    new QueueRetryCommand(),
    new QueueClearCommand(),
]);

/**
 * Dynamic Command Loading from Site Profile and Modules
 * This scans site/commands/ and site/modules/[module]/commands/ directories.
 * It uses a simple namespace parser so the commands can have custom namespaces.
 */
if ($wire instanceof \ProcessWire\ProcessWire) {
    try {
        $commandPaths = [
            $wire->config->paths->site . 'commands/',
        ];

        // Include any module that has a commands/ directory
        $modulesPath = $wire->config->paths->siteModules;
        if (is_dir($modulesPath)) {
            $matchedModules = glob($modulesPath . '*/commands/', GLOB_ONLYDIR) ?: [];
            $commandPaths = array_merge($commandPaths, $matchedModules);
        }

        foreach ($commandPaths as $siteCommandsPath) {
            if (is_dir($siteCommandsPath)) {
                $files = glob($siteCommandsPath . '*Command.php');
                if ($files) {
                    foreach ($files as $file) {
                        require_once $file;
                        
                        // Parse the namespace if it exists (simple regex for basic parsing)
                        $namespace = '';
                        $content = file_get_contents($file);
                        if (preg_match('/namespace\s+([^;]+);/', $content, $matches)) {
                            $namespace = trim($matches[1]) . chr(92);
                        }
                        
                        $className = $namespace . basename($file, '.php');
                        
                        if (class_exists($className)) {
                            $cmd = new $className();
                            if ($cmd instanceof \Symfony\Component\Console\Command\Command) {
                                $application->add($cmd);
                            }
                        }
                    }
                }
            }
        }
    } catch (\Throwable $e) {
        // Silently fail site-specific command loading
    }
}

/**
 * External Package Commands (Composer-driven auto-discovery)
 * Reads vendor/composer/installed.json for global vendor packages
 * that declare: "extra": { "processwire-console": { "commands": ["FQCN", ...] } }
 */
try {
    // Globally installed Vendor Package auto-discovery
    $vendorRoot = dirname($autoloader, 2); // e.g., project root
    $installedJson = $vendorRoot . '/vendor/composer/installed.json';
    if (is_file($installedJson)) {
        $jsonStr = file_get_contents($installedJson);
        if (is_string($jsonStr)) {
            $json = json_decode($jsonStr, true);
            if (is_array($json)) {
                $packages = $json;
                if (array_key_exists('packages', $json)) {
                    $packages = $json['packages'];
                }
                if (is_array($packages)) {
                    foreach ($packages as $pkg) {
                        if (is_array($pkg) && isset($pkg['extra']['processwire-console']['commands']) && is_array($pkg['extra']['processwire-console']['commands'])) {
                            foreach ($pkg['extra']['processwire-console']['commands'] as $fqcn) {
                                if (is_string($fqcn) && class_exists($fqcn)) {
                                    $cmd = new $fqcn();
                                    if ($cmd instanceof \Symfony\Component\Console\Command\Command) {
                                        $application->add($cmd);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    // Support path repositories defined in root composer.json
    $rootComposer = $vendorRoot . '/composer.json';
    if (is_file($rootComposer)) {
        $rootCfg = json_decode((string)file_get_contents($rootComposer), true);
        $repos = $rootCfg['repositories'] ?? [];
        foreach ($repos as $repo) {
            if (($repo['type'] ?? '') !== 'path') continue;
            $url = $repo['url'] ?? '';
            if ($url === '') continue;
            $pkgComposer = $vendorRoot . '/' . trim($url, '/') . '/composer.json';
            if (!is_file($pkgComposer)) continue;
            $pkgCfg = json_decode((string)file_get_contents($pkgComposer), true);
            $extra = $pkgCfg['extra']['processwire-console']['commands'] ?? null;
            if (is_array($extra)) {
                foreach ($extra as $fqcn) {
                    if (is_string($fqcn) && class_exists($fqcn)) {
                        $cmd = new $fqcn();
                        if ($cmd instanceof \Symfony\Component\Console\Command\Command) {
                            $application->add($cmd);
                        }
                    }
                }
            }
        }
    }
} catch (\Throwable $e) {
    // ignore discovery errors
}

$application->run();
